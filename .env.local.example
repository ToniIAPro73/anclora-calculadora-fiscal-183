# CONFIGURACIÓN DE STRIPE 2026
# Obtén estas claves en tu Dashboard de Stripe -> Developers -> API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_tu_clave_publica_aqui
STRIPE_SECRET_KEY=sk_test_tu_clave_privada_aqui

# CONFIGURACIÓN DEL PRODUCTO (PDF)
# Crea un producto en Stripe y pega aquí el ID del Precio
VITE_STRIPE_PRICE_ID=price_XXXXXXXXXXXX
VITE_CURRENCY=EUR

# METADATOS DE LA APLICACIÓN (Optimización AEO)
VITE_APP_URL=https://tu-dominio-final.com
VITE_APP_VERSION=1.0.0-april2026

# GOOGLE ADS (Opcional)
VITE_GOOGLE_ADS_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX